# Optional app password for deployed access.
KATLAS_APP_PASSWORD=choose_a_private_password

# OpenRouter AI provider. Server-side only, never expose this with a VITE_ prefix.
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_DEFAULT_MODEL=openrouter_model_id
OPENROUTER_FALLBACK_MODEL=optional_fallback_model_id
